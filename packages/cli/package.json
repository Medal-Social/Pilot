{
  "name": "@medalsocial/pilot",
  "version": "0.2.4",
  "type": "module",
  "description": "Your AI crew, ready to fly. Medal Social's AI-powered CLI platform.",
  "license": "Apache-2.0",
  "keywords": [
    "cli",
    "ai",
    "agent",
    "medal",
    "social",
    "pilot",
    "crew",
    "anthropic",
    "claude",
    "gemini",
    "codex",
    "marketing",
    "cto",
    "cmo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Medal-Social/Pilot.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Medal-Social/Pilot/issues"
  },
  "homepage": "https://github.com/Medal-Social/Pilot#readme",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "bin": {
    "pilot": "dist/bin/pilot.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!dist/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsx watch src/bin/pilot.ts",
    "build": "node scripts/inject-version.mjs && tsc",
    "test": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "node scripts/inject-version.mjs && tsc"
  },
  "dependencies": {
    "@medalsocial/kit": "workspace:*",
    "commander": "14.0.3",
    "ink": "7.0.2",
    "react": "19.2.6",
    "smol-toml": "1.6.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "ink-testing-library": "4.0.0",
    "react-devtools-core": "^7.0.1",
    "tsx": "4.21.0"
  }
}
