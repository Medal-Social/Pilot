{
  "name": "@medalsocial/pilot-monorepo",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter @medalsocial/pilot dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test:repo": "vitest run tests/",
    "test": "turbo test",
    "quality": "pnpm lint && pnpm typecheck && pnpm test:repo && pnpm test",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "changeset": "changeset",
    "changeset:auto": "node scripts/changeset-auto.mjs",
    "changeset:check": "node scripts/changeset-auto.mjs --check",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "secret:scan": "node scripts/secretlint-repo.mjs",
    "secret:scan:staged": "node scripts/secretlint-staged.mjs",
    "knip:report": "knip --reporter json --no-exit-code",
    "knip:check": "knip",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,md,yml,yaml}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.3",
    "@secretlint/secretlint-rule-preset-recommend": "^12.3.1",
    "@vitest/coverage-v8": "^4.1.5",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "secretlint": "^12.3.1",
    "turbo": "2.9.6",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
